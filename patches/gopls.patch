+type testImporter map[string]*types.Package
+
+func (m testImporter) Import(path string) (*types.Package, error) {
+	if pkg := m[path]; pkg != nil {
+		return pkg, nil
+	}
+	return nil, fmt.Errorf("package %q not found", path)
+}
+
+func TestEnum(t *testing.T) {
+	const src = `package p
+
+type Option[T any] enum {
+	Some { Value T }
+	None
+}
+
+type Empty enum {}
+
+func use(option Option[string]) {
+	switch option {
+	case Some:
+		_ = option.Value
+	}
+}
+
+func useEmpty(empty Empty) {
+	switch empty {
+	}
+}
+
+type Alias = Option[string]
+
+func useAlias(option Alias) {
+	switch option {
+	}
+}
+`
+	fset := token.NewFileSet()
+	file, err := parser.ParseFile(fset, "enum.go", src, 0)
+	if err != nil {
+		t.Fatal(err)
+	}
+	info := &types.Info{
+		Types:      make(map[ast.Expr]types.TypeAndValue),
+		Defs:       make(map[*ast.Ident]types.Object),
+		Uses:       make(map[*ast.Ident]types.Object),
+		Implicits:  make(map[ast.Node]types.Object),
+		Scopes:     make(map[ast.Node]*types.Scope),
+		Selections: make(map[*ast.SelectorExpr]*types.Selection),
+	}
+	config := &types.Config{Error: func(error) {}}
+	pkg, _ := config.Check("p", fset, []*ast.File{file}, info)
+	diagnostics := fillswitch.Diagnose(file, token.NoPos, token.NoPos, pkg, info)
+	if len(diagnostics) != 3 {
+		t.Fatalf("got %d diagnostics, want 3", len(diagnostics))
+	}
+	fix := diagnostics[0].SuggestedFixes[0]
+	if len(fix.TextEdits) != 1 {
+		t.Fatalf("got %d edits, want 1", len(fix.TextEdits))
+	}
+	text := string(fix.TextEdits[0].NewText)
+	if !strings.Contains(text, "case None:") || !strings.Contains(text, "case nil:") || strings.Contains(text, "case Some:") {
+		t.Fatalf("enum switch edit = %q", text)
+	}
+	if !strings.HasSuffix(text, "\t") {
+		t.Fatalf("enum switch edit does not preserve closing-brace indentation: %q", text)
+	}
+	emptyFix := diagnostics[1].SuggestedFixes[0]
+	if len(emptyFix.TextEdits) != 1 {
+		t.Fatalf("got %d empty-enum edits, want 1", len(emptyFix.TextEdits))
+	}
+	emptyText := string(emptyFix.TextEdits[0].NewText)
+	if !strings.Contains(emptyText, "case nil:") || strings.Contains(emptyText, "case None:") {
+		t.Fatalf("empty enum switch edit = %q", emptyText)
+	}
+	aliasText := string(diagnostics[2].SuggestedFixes[0].TextEdits[0].NewText)
+	if !strings.Contains(aliasText, "case Some:") || !strings.Contains(aliasText, "case None:") || !strings.Contains(aliasText, "case nil:") {
+		t.Fatalf("aliased enum switch edit = %q", aliasText)
+	}
+}
+
+func TestEnumTypeSwitchCoveringCases(t *testing.T) {
+	const src = `package p
+
+type Result enum { Ok; Err }
+
+func enumCase(result Result) {
+	switch result.(type) {
+	case Result:
+	}
+}
+
+func anyCase(result Result) {
+	switch result.(type) {
+	case any:
+	}
+}
+`
+	fset := token.NewFileSet()
+	file, err := parser.ParseFile(fset, "enum.go", src, 0)
+	if err != nil {
+		t.Fatal(err)
+	}
+	info := &types.Info{
+		Types:      make(map[ast.Expr]types.TypeAndValue),
+		Defs:       make(map[*ast.Ident]types.Object),
+		Uses:       make(map[*ast.Ident]types.Object),
+		Implicits:  make(map[ast.Node]types.Object),
+		Scopes:     make(map[ast.Node]*types.Scope),
+		Selections: make(map[*ast.SelectorExpr]*types.Selection),
+	}
+	config := &types.Config{Error: func(error) {}}
+	pkg, _ := config.Check("p", fset, []*ast.File{file}, info)
+	diagnostics := fillswitch.Diagnose(file, token.NoPos, token.NoPos, pkg, info)
+	if len(diagnostics) != 2 {
+		t.Fatalf("got %d diagnostics, want 2", len(diagnostics))
+	}
+	for _, diagnostic := range diagnostics {
+		text := string(diagnostic.SuggestedFixes[0].TextEdits[0].NewText)
+		if !strings.Contains(text, "case nil:") || strings.Contains(text, "case Ok:") || strings.Contains(text, "case Err:") {
+			t.Fatalf("covering type-switch edit = %q, want only nil", text)
+		}
+	}
+}
+
+func TestEnumExistingDefault(t *testing.T) {
+	fset := token.NewFileSet()
+	parse := func(name, src string) *ast.File {
+		file, err := parser.ParseFile(fset, name, src, 0)
+		if err != nil {
+			t.Fatal(err)
+		}
+		return file
+	}
+
+	decl := parse("enum.go", `package p; type E enum { A; B; private }`)
+	pkg, err := new(types.Config).Check("p", fset, []*ast.File{decl}, nil)
+	if err != nil {
+		t.Fatal(err)
+	}
+	use := parse("use.go", `package q
+import "p"
+func use(value p.E) {
+	switch value {
+	case A:
+	default:
+	}
+}
+func useType(value p.E) {
+	switch value.(type) {
+	case A:
+	default:
+	}
+}`)
+	info := &types.Info{
+		Types:      make(map[ast.Expr]types.TypeAndValue),
+		Defs:       make(map[*ast.Ident]types.Object),
+		Uses:       make(map[*ast.Ident]types.Object),
+		Implicits:  make(map[ast.Node]types.Object),
+		Scopes:     make(map[ast.Node]*types.Scope),
+		Selections: make(map[*ast.SelectorExpr]*types.Selection),
+	}
+	consumer, err := (&types.Config{Importer: testImporter{"p": pkg}}).Check("q", fset, []*ast.File{use}, info)
+	if err != nil {
+		t.Fatal(err)
+	}
+	diagnostics := fillswitch.Diagnose(use, token.NoPos, token.NoPos, consumer, info)
+	if len(diagnostics) != 2 {
+		t.Fatalf("got %d diagnostics, want 2", len(diagnostics))
+	}
+	for _, diagnostic := range diagnostics {
+		text := string(diagnostic.SuggestedFixes[0].TextEdits[0].NewText)
+		if !strings.Contains(text, "case B:") || strings.Contains(text, "default:") || strings.Contains(text, "case nil:") {
+			t.Fatalf("enum switch edit = %q, want B without duplicate default or nil", text)
+		}
+		if !strings.HasSuffix(text, "\t") {
+			t.Fatalf("enum switch edit does not preserve closing-brace indentation: %q", text)
+		}
+	}
+}
