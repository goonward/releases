+func TestEnumTooling(t *testing.T) {
+	const source = `
+-- go.mod --
+module example.com/p
+
+go 1.28
+-- enum.go --
+package p
+
+// Result reports success or failure.
+type Result enum {
+	// Ok carries a value.
+	Ok { Value int }
+	Err { Message string }
+}
+
+// Same parent documentation.
+type Same enum {
+	// Same variant documentation.
+	Same
+}
+
+var Success int
+
+func (result Result) Or(fallback int) int {
+	switch result {
+	case Ok:
+		return result.Value
+	case Err, nil:
+		return fallback
+	}
+	return fallback
+}
+
+func use(result Result) int {
+	return result.Or(1)
+}
+
+func qualified() Result {
+	return Result.Ok{Value: 1}
+}
+-- client/client.go --
+package client
+
+import "example.com/p"
+
+var _ p.Result = p.Result.Ok{Value: 2}
+`
+	WithOptions(Modes(Default)).Run(t, source, func(t *testing.T, env *Env) {
+		env.OpenFile("enum.go")
+		env.OpenFile("client/client.go")
+
+		parent, _ := env.Hover(env.RegexpSearch("enum.go", `type (Result) enum`))
+		if !strings.Contains(parent.Value, "type Result enum") || !strings.Contains(parent.Value, "Result reports success") {
+			t.Errorf("Result hover = %q", parent.Value)
+		}
+
+		variant, _ := env.Hover(env.RegexpSearch("enum.go", `\t(Ok) \{`))
+		if !strings.Contains(variant.Value, "type Result enum") || !strings.Contains(variant.Value, "Ok carries a value") || strings.Contains(variant.Value, ".enum.Result") {
+			t.Errorf("Ok hover = %q", variant.Value)
+		}
+
+		sameParent, _ := env.Hover(env.RegexpSearch("enum.go", `type (Same) enum`))
+		if !strings.Contains(sameParent.Value, "Same parent documentation") {
+			t.Errorf("Same parent hover = %q", sameParent.Value)
+		}
+		sameVariant, _ := env.Hover(env.RegexpSearch("enum.go", `\t(Same)\n`))
+		if !strings.Contains(sameVariant.Value, "Same variant documentation") || strings.Contains(sameVariant.Value, "Same parent documentation") {
+			t.Errorf("Same variant hover = %q", sameVariant.Value)
+		}
+
+		signatures := env.SignatureHelp(env.RegexpSearch("enum.go", `result\.Or\(()1`))
+		if len(signatures.Signatures) != 1 || signatures.Signatures[0].Label != "Or(fallback int) int" {
+			t.Errorf("Or signatures = %#v", signatures.Signatures)
+		}
+
+		use := env.RegexpSearch("enum.go", `Result\.(Ok)\{`)
+		decl := env.RegexpSearch("enum.go", `\t(Ok) \{`)
+		if diff := cmp.Diff(decl, env.FirstDefinition(use)); diff != "" {
+			t.Errorf("Ok definition mismatch (-want +got):\n%s", diff)
+		}
+		for _, conflict := range []string{"Err", "Or"} {
+			if err := env.Editor.Rename(env.Ctx, use, conflict); err == nil {
+				t.Errorf("renaming Ok to conflicting name %q succeeded", conflict)
+			}
+		}
+
+		env.Rename(use, "Success")
+		text := env.BufferText("enum.go")
+		for _, want := range []string{"Success { Value int }", "case Success:", "Result.Success{Value: 1}"} {
+			if !strings.Contains(text, want) {
+				t.Errorf("renamed enum is missing %q:\n%s", want, text)
+			}
+		}
+		if text := env.BufferText("client/client.go"); !strings.Contains(text, "p.Result.Success{Value: 2}") {
+			t.Errorf("renamed imported enum variant is missing from client:\n%s", text)
+		}
+	})
+}
