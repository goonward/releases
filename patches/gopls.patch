+func TestEnumVariantCompletion(t *testing.T) {
+	const files = `
+-- go.mod --
+module example.com
+
+go 1.28
+-- enum.go --
+package example
+
+type Result enum {
+	Ok { Value int }
+	Err { Message string }
+}
+
+var _ = Result.
+`
+
+	WithOptions(Modes(Default)).Run(t, files, func(t *testing.T, env *Env) {
+		env.OpenFile("enum.go")
+		items := env.Completion(env.RegexpSearch("enum.go", `Result\.()`))
+		labels := completionLabels(items.Items)
+		if !slices.Contains(labels, "Ok") || !slices.Contains(labels, "Err") || slices.Contains(labels, "Result.Ok") {
+			t.Errorf("Result completion labels: %v", labels)
+		}
+	})
+}
+
+func completionLabels(items []protocol.CompletionItem) []string {
+	labels := make([]string, len(items))
+	for i, item := range items {
+		labels[i] = item.Label
+	}
+	return labels
+}
