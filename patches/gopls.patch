+// sourceName returns the identifier spelling used at an object's declaration.
+// Enum variant type objects have a qualified package-local name (Result.Ok),
+// while their declaring identifier is only the final component (Ok).
+func sourceName(obj types.Object) string {
+	name := obj.Name()
+	tname, _ := obj.(*types.TypeName)
+	if tname == nil {
+		return name
+	}
+	named, _ := types.Unalias(tname.Type()).(*types.Named)
+	if named != nil {
+		if enumType := named.EnumType(); enumType != nil && enumType.Origin() != named.Origin() {
+			if i := strings.LastIndexByte(name, '.'); i >= 0 {
+				return name[i+1:]
+			}
+		}
+	}
+	return name
+}
