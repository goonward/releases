+func TestEnumSwitchNarrowingCompletion(t *testing.T) {
+	const files = `
+-- go.mod --
+module example.com
+
+go 1.28
+-- enum.go --
+package example
+
+type Result enum {
+	Ok { Value int }
+	Err { Message string }
+}
+
+func use(r Result) {
+	switch r {
+	case Ok:
+		r.
+	case Err:
+		r.
+	case nil:
+	}
+}
+`
+
+	WithOptions(Modes(Default)).Run(t, files, func(t *testing.T, env *Env) {
+		env.OpenFile("enum.go")
+		ok := env.Completion(env.RegexpSearch("enum.go", `case Ok:\n\t\tr\.()`))
+		okLabels := completionLabels(ok.Items)
+		if !slices.Contains(okLabels, "Value") || slices.Contains(okLabels, "Message") || slices.Contains(okLabels, ".enum.Result") {
+			t.Errorf("Ok completion labels: %v", okLabels)
+		}
+		err := env.Completion(env.RegexpSearch("enum.go", `case Err:\n\t\tr\.()`))
+		errLabels := completionLabels(err.Items)
+		if !slices.Contains(errLabels, "Message") || slices.Contains(errLabels, "Value") || slices.Contains(errLabels, ".enum.Result") {
+			t.Errorf("Err completion labels: %v", errLabels)
+		}
+	})
+}
