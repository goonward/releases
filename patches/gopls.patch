+func TestResolveTryStmt(t *testing.T) {
+	const src = `package p
+func load() (int, error) { return 0, nil }
+func get() (int, error) {
+	try value := load()
+	return value, nil
+}
+`
+	pgf, _ := Parse(context.Background(), token.NewFileSet(), "file://try.go", []byte(src), Full, false)
+	pgf.Resolve()
+	fn := pgf.File.Decls[1].(*ast.FuncDecl)
+	stmt := fn.Body.List[0].(*ast.TryStmt)
+	def := stmt.Lhs[0].(*ast.Ident)
+	use := fn.Body.List[1].(*ast.ReturnStmt).Results[0].(*ast.Ident)
+	if def.Obj == nil || use.Obj != def.Obj {
+		t.Fatalf("try binding did not resolve: def=%p use=%p", def.Obj, use.Obj)
+	}
+}
