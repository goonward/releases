+func suggestedFixEnumSwitch(end token.Pos, body *ast.BlockStmt, tag ast.Expr, namedType *types.Named, typeSwitch bool, pkg *types.Package, info *types.Info) *analysis.SuggestedFix {
+	variants := namedType.EnumVariants()
+
+	var existing []types.Type
+	hasNil := false
+	hasDefault := false
+	for _, stmt := range body.List {
+		clause := stmt.(*ast.CaseClause)
+		if clause.List == nil {
+			hasDefault = true
+		}
+		for _, expr := range clause.List {
+			if id, ok := expr.(*ast.Ident); ok {
+				if _, ok := info.ObjectOf(id).(*types.Nil); ok {
+					hasNil = true
+					continue
+				}
+			}
+			if typ := info.TypeOf(expr); typ != nil {
+				existing = append(existing, typ)
+			}
+		}
+	}
+
+	covered := func(variant types.Type) bool {
+		for _, typ := range existing {
+			if types.Identical(typ, variant) || typeSwitch && types.AssignableTo(variant, typ) {
+				return true
+			}
+		}
+		return false
+	}
+
+	var buf bytes.Buffer
+	inaccessible := false
+	qualifier := typesinternal.NameRelativeTo(pkg)
+	for _, variant := range variants {
+		if covered(variant) {
+			continue
+		}
+		obj := variant.Obj()
+		if obj.Pkg() != pkg && !obj.Exported() {
+			inaccessible = true
+			continue
+		}
+		if buf.Len() > 0 {
+			buf.WriteByte('\t')
+		}
+		name := variant.Obj().Name()
+		if i := strings.LastIndexByte(name, '.'); i >= 0 {
+			name = name[i+1:]
+		}
+		fmt.Fprintf(&buf, "case %s:\n", name)
+	}
+
+	if inaccessible && !hasDefault {
+		if buf.Len() > 0 {
+			buf.WriteByte('\t')
+		}
+		addDefaultCase(&buf, namedType, tag)
+	} else if !hasNil && !hasDefault {
+		if buf.Len() > 0 {
+			buf.WriteByte('\t')
+		}
+		buf.WriteString("case nil:\n")
+	}
+	if buf.Len() == 0 {
+		return nil
+	}
+	if !inaccessible || hasDefault {
+		buf.WriteByte('\t')
+	}
+
+	return &analysis.SuggestedFix{
+		Message: "Add cases for " + types.TypeString(namedType, qualifier),
+		TextEdits: []analysis.TextEdit{{
+			Pos:     end - token.Pos(len("}")),
+			End:     end - token.Pos(len("}")),
+			NewText: buf.Bytes(),
+		}},
+	}
+}
