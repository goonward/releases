+// enumSwitchStmt emits an ordinary switch over an enum as a sequence of type
+// tests. go/types records the narrowed tag variable as each clause's implicit
+// variable, just as it does for a type switch.
+func (b *builder) enumSwitchStmt(fn *Function, s *ast.SwitchStmt, label *lblock) {
+	if s.Init != nil {
+		b.stmt(fn, s.Init)
+	}
+	x := b.expr(fn, s.Tag)
+	done := fn.newBasicBlock("enumswitch.done")
+	if label != nil {
+		label._break = done
+	}
+	var default_ *ast.CaseClause
+	for _, clause := range s.Body.List {
+		cc := clause.(*ast.CaseClause)
+		if cc.List == nil {
+			default_ = cc
+			continue
+		}
+		body := fn.newBasicBlock("enumswitch.body")
+		var next *BasicBlock
+		var narrowed Value
+		for _, cond := range cc.List {
+			next = fn.newBasicBlock("enumswitch.next")
+			caseType := fn.typeOf(cond)
+			var condition Value
+			if caseType == tUntypedNil {
+				condition = emitCompare(fn, token.EQL, x, zeroConst(x.Type()), cond.Pos())
+				narrowed = x
+			} else {
+				test := emitTypeTest(fn, x, caseType, cc.Case)
+				narrowed = emitExtract(fn, test, 0)
+				condition = emitExtract(fn, test, 1)
+			}
+			emitIf(fn, condition, body, next)
+			fn.currentBlock = next
+		}
+		if len(cc.List) != 1 {
+			narrowed = x
+		}
+		fn.currentBlock = body
+		b.typeCaseBody(fn, cc, narrowed, done)
+		fn.currentBlock = next
+	}
+	if default_ != nil {
+		b.typeCaseBody(fn, default_, x, done)
+	} else {
+		emitJump(fn, done)
+	}
+	fn.currentBlock = done
+}
